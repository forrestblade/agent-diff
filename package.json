{
  "name": "agentdiff",
  "version": "0.1.0",
  "type": "module",
  "description": "Post-session CLI that diffs the repo and produces a structured summary",
  "bin": {
    "agent-diff": "bin/agent-diff.js"
  },
  "files": [
    "dist",
    "bin"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint .",
    "validate": "tsc --noEmit && eslint .",
    "prepublishOnly": "npm run validate && npm run build"
  },
  "author": "Forrest",
  "license": "MIT",
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@valencets/resultkit": "^0.2.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^4.0.0",
    "neostandard": "^0.12.0",
    "typescript": "^5.9.0",
    "vitest": "^4.0.0"
  }
}
